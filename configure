#!/bin/sh

# Detect OS
OS=`uname -s`

if [ "$OS" = "Darwin" ] || [ "$OS" = "Linux" ]; then
    # Mac and Linux: use gsl-config
    if ! command -v gsl-config > /dev/null 2>&1; then
        echo "----------------------------------------------------"
        echo "ERROR: gsl-config not found."
        echo "Please install GSL:"
        echo "  Mac:    brew install gsl"
        echo "  Ubuntu: sudo apt-get install libgsl-dev"
        echo "  Fedora: sudo dnf install gsl-devel"
        echo "----------------------------------------------------"
        exit 1
    fi

    GSL_CFLAGS=`gsl-config --cflags`
    GSL_LIBS=`gsl-config --libs`

else
    # Windows: rely on Rtools
    GSL_CFLAGS="-I${R_TOOLS_SOFT}/include"
    GSL_LIBS="-L${R_TOOLS_SOFT}/lib -lgsl -lgslcblas"
fi

sed -e "s|@GSL_CFLAGS@|${GSL_CFLAGS}|" \
    -e "s|@GSL_LIBS@|${GSL_LIBS}|" \
    src/Makevars.in > src/Makevars

echo "GSL_CFLAGS: ${GSL_CFLAGS}"
echo "GSL_LIBS:   ${GSL_LIBS}"