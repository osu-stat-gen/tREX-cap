\name{human1422}
\alias{human1422}
\docType{data}
\title{
Hi-C data of 1Mb based on HindIII restriction enzyme of chromosome 14 and 22 from Lieberman-Aiden et al. (2009).
}
\description{
There are two Hi-C experiments performed on the same karyotypical normal human lymphoblastoid cell line, which are combined into a single data set in our analysis given their high reproducibility. The first 89 fragemtns are for chromosome 14 and the last 36 fragments are for chromosome 22.
}
\usage{data("human1422")}
\format{
The sim_hic is a matrix of 125x125.
}
\references{
Park, J. and Lin, S. A random effect model for reconstruction of spatial chromatin structure. Biometrics. 2016 May 23. Epub ahead of print].
Park, J. and Lin, S. Impact of data resolution on three-dimensional structure inference methods, BMC Bioinfomatics. 2016;17:70.
Lieberman-Aiden E, van Berkum NL, Williams L, Imakaev M, Ragoczy T, Telling A, et al. Comprehensive mapping of long-range interactions reveals folding principles of the human genome. Science. 2009;326(5950): 289–93. doi:10.1126/science.1181369. 
}
\examples{
data(human1422)
}
\keyword{datasets}
