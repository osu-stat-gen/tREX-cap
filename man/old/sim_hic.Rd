\name{sim_hic}
\alias{sim_hic}
\docType{data}
\title{
	Simulated Hi-C data using a mouse underlying structure of 43 loci fragments.
}
\description{
The sim_hic is a simulated data using Poisson random effects structure model with 30 percent of zeros using zero inflated Poisson model.
}
\usage{data("sim_hic")}
\format{
The sim_hic is a matrix of 43x43.
}
\references{
Park, J. and Lin, S. A random effect model for reconstruction of spatial chromatin structure. Biometrics. 2016 May 23. Epub ahead of print].
Park, J. and Lin, S. Impact of data resolution on three-dimensional structure inference methods, BMC Bioinfomatics. 2016;17:70.
}
\examples{
data(sim_hic)
}
\keyword{datasets}
